# Postgres (use Neon em produção: https://neon.tech)
DATABASE_URL="postgresql://user:pass@host:5432/minerador?sslmode=require"

# Apify API token — pega em https://console.apify.com/account/integrations
APIFY_TOKEN="apify_api_xxx"

# Actor ID do scraper (curious_coder/facebook-ads-library-scraper)
APIFY_ACTOR_ID="curious_coder~facebook-ads-library-scraper"

# Secret pra proteger o endpoint de cron (qualquer string aleatória longa)
CRON_SECRET="troque-isso-por-uma-string-aleatoria-grande"
